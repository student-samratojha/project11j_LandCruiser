<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Gallery — Land Cruiser</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      @keyframes shine {
        from {
          background-position: 200% center;
        }
        to {
          background-position: -200% center;
        }
      }
      .sem {
        position: relative;
      }
      .sem::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: 5px;
        width: 95%;
        height: 1px;
        background: #c084fc;
        opacity: 0;
        transition: 0.3s;
      }
      .sem:hover::after {
        bottom: -2px;
        opacity: 1;
      }
      .sem:hover {
        color: #c084fc;
      }
      .card-image {
        transition:
          transform 450ms cubic-bezier(0.2, 0.8, 0.2, 1),
          box-shadow 300ms;
      }
      .card:hover .card-image {
        transform: translateY(-4px) scale(1.04);
      }
    </style>
  </head>
  <body class="bg-black text-white font-sans min-h-screen flex flex-col justify-between overflow-x-hidden">
    
    <!-- Navigation (Same as Home Theme) -->
    <nav class="relative z-50 w-full bg-black/10 backdrop-blur-xl border-b border-white/5 font-[Inter]">
      <div class="mx-auto max-w-7xl flex items-center justify-between px-6 py-5">
        <!-- Logo -->
        <a
          href="/"
          class="animate-[shine_7s_linear_infinite] bg-[linear-gradient(90deg,#000,#1A0B2E_20%,#8A2BE2_50%,#D8B4FE_75%,#000)] bg-[length:200%_100%] bg-clip-text text-transparent text-lg font-extrabold tracking-[.35em] uppercase"
        >
          LAND CRUISER
        </a>

        <!-- Desktop Menu -->
        <div class="hidden md:flex items-center gap-8 uppercase text-sm tracking-[.22em] text-white/70">
          <a class="sem" href="/">Home</a>
          <a class="sem" href="/about">About</a>
          <a class="sem" href="/contact/models">Models</a>
          <a
            href="/auth/login"
            class="border border-white/20 px-5 py-2 rounded-full hover:border-violet-400 hover:text-violet-300 transition"
          >
            Login
          </a>
        </div>

        <!-- Mobile Toggle Button -->
        <div class="md:hidden flex items-center gap-3">
          <a href="/auth/login" class="text-sm border border-white/20 px-3 py-1 rounded-full text-white/90">
            Login
          </a>
          <button id="menu-btn" class="text-2xl focus:outline-none z-50 relative p-1">
            ☰
          </button>
        </div>
      </div>

      <!-- Mobile Menu Drawer -->
      <div id="mobile-menu" class="hidden fixed inset-0 z-40 bg-black/95 backdrop-blur-2xl flex flex-col items-center justify-center gap-6 uppercase text-base tracking-[.25em] text-white/80 transition-all duration-300">
        <a class="sem py-2 text-lg" href="/">Home</a>
        <a class="sem py-2 text-lg" href="/contact/models">Models</a>
        <a class="sem py-2 text-lg" href="/gallery">Gallery</a>
        
        <div class="flex flex-col w-full px-12 gap-4 mt-6">
          <a href="/auth/login" class="text-center border border-white/20 py-3 rounded-full hover:border-violet-400 hover:text-violet-300 transition">
            Login
          </a>
          <a href="/auth/register" class="text-center rounded-full bg-violet-600 py-3 text-white hover:bg-violet-500 transition">
            Register
          </a>
        </div>
      </div>
    </nav>

    <!-- Main Content Area -->
    <main class="mx-auto max-w-7xl px-6 py-12 relative z-10 flex-grow w-full">
      
      <!-- Ambient Glow Background effects -->
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -z-10 w-[500px] h-[500px] bg-violet-900/10 rounded-full blur-[120px] pointer-events-none"></div>

      <!-- Header Section -->
      <div class="text-center">
        <div class="inline-block rounded-full border border-white/10 bg-white/5 backdrop-blur-xl shadow-[0_0_30px_rgba(138,43,226,.18)] px-5 py-2 text-[11px] uppercase tracking-[.35em] animate-[shine_9s_linear_infinite] bg-[linear-gradient(90deg,#000,#1A0B2E,#8A2BE2,#D8B4FE,#000)] bg-[length:200%_100%] bg-clip-text text-transparent">
          Luxury · Performance · Legacy
        </div>
        <h1 class="mt-6 text-3xl font-light sm:text-4xl md:text-5xl leading-tight bg-[linear-gradient(90deg,#fff,#d8b4fe,#8A2BE2)] bg-clip-text text-transparent">
          Signature Black — <span class="font-semibold">Gallery</span>
        </h1>
        <p class="mt-4 max-w-2xl mx-auto text-sm sm:text-base text-gray-300 italic">
          Discover the premium black Land Cruiser experience across refined environments and distinct angles.
        </p>
      </div>

      <!-- Cards Grid -->
      <div class="mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Card 1 -->
        <div class="card group rounded-2xl overflow-hidden border border-white/10 bg-white/5 backdrop-blur-md shadow-lg transition-all hover:border-[#8A2BE2]/40 hover:shadow-[0_0_20px_rgba(138,43,226,0.15)]">
          <div class="h-64 w-full bg-black overflow-hidden relative">
            <img
              src="./hero.jpg"
              alt="Land Cruiser - Front"
              class="card-image h-full w-full object-cover object-center"
            />
          </div>
          <div class="p-6">
            <h3 class="text-lg font-semibold tracking-wide text-white/90">Signature Front</h3>
            <p class="mt-2 text-sm text-gray-400 leading-relaxed">
              The iconic grille and commanding stance, captured in premium black.
            </p>
            <div class="mt-6 flex items-center justify-between border-t border-white/5 pt-4">
              <span class="text-xs tracking-wider text-white/40 uppercase">2026 • Signature</span>
              <a
                href="./hero.jpg"
                target="_blank"
                class="text-xs uppercase tracking-widest text-[#C084FC] hover:text-white transition font-medium"
                >Open</a
              >
            </div>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="card group rounded-2xl overflow-hidden border border-white/10 bg-white/5 backdrop-blur-md shadow-lg transition-all hover:border-[#8A2BE2]/40 hover:shadow-[0_0_20px_rgba(138,43,226,0.15)]">
          <div class="h-64 w-full bg-black overflow-hidden relative">
            <img
              src="./heros.png"
              alt="Land Cruiser - Side"
              class="card-image h-full w-full object-cover object-center"
            />
          </div>
          <div class="p-6">
            <h3 class="text-lg font-semibold tracking-wide text-white/90">Elegant Profile</h3>
            <p class="mt-2 text-sm text-gray-400 leading-relaxed">
              A striking silhouette that balances raw luxury and unmatched off-road capability.
            </p>
            <div class="mt-6 flex items-center justify-between border-t border-white/5 pt-4">
              <span class="text-xs tracking-wider text-white/40 uppercase">Exterior</span>
              <a
                href="./heros.png"
                target="_blank"
                class="text-xs uppercase tracking-widest text-[#C084FC] hover:text-white transition font-medium"
                >Open</a
              >
            </div>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="card group rounded-2xl overflow-hidden border border-white/10 bg-white/5 backdrop-blur-md shadow-lg transition-all hover:border-[#8A2BE2]/40 hover:shadow-[0_0_20px_rgba(138,43,226,0.15)]">
          <div class="h-64 w-full bg-black overflow-hidden relative">
            <img
              src="./about.png"
              alt="Land Cruiser - Detail"
              class="card-image h-full w-full object-cover object-center"
            />
          </div>
          <div class="p-6">
            <h3 class="text-lg font-semibold tracking-wide text-white/90">Interior Detail</h3>
            <p class="mt-2 text-sm text-gray-400 leading-relaxed">
              Premium finishes, meticulous design, and material quality tailored for comfort.
            </p>
            <div class="mt-6 flex items-center justify-between border-t border-white/5 pt-4">
              <span class="text-xs tracking-wider text-white/40 uppercase">Interior</span>
              <a
                href="./about.png"
                target="_blank"
                class="text-xs uppercase tracking-widest text-[#C084FC] hover:text-white transition font-medium"
                >Open</a
              >
            </div>
          </div>
        </div>
      </div>

      <!-- Action Button matching home page styling -->
      <div class="mt-14 text-center">
        <a
          href="/contact/models"
          class="rounded-full inline-block border border-[#8A2BE2]/40 text-sm bg-[#8A2BE2]/10 px-8 py-3 backdrop-blur-xl hover:shadow-[0_0_12px_rgba(138,43,226,.6)] transition"
          >Explore Models</a
        >
      </div>
    </main>

    <!-- Footer Area (Same as Home Theme) -->
    <footer class="border-t border-white/5 bg-black/95 w-full">
      <div class="mx-auto max-w-7xl px-6 py-8 text-center text-xs tracking-widest text-white/40 uppercase">
        © 2026 Signature Edition Land Cruiser — All rights reserved.
      </div>
    </footer>

    <!-- Mobile Menu Toggle Handler Script -->
    <script>
      const menuBtn = document.getElementById('menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      menuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
        if (mobileMenu.classList.contains('hidden')) {
          menuBtn.innerHTML = '☰';
        } else {
          menuBtn.innerHTML = '✕';
        }
      });
    </script>
  </body>
</html>