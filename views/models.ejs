<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Models — Land Cruiser</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      @keyframes shine {
        from {
          background-position: 200% center;
        }
        to {
          background-position: -200% center;
        }
      }
      .sem {
        position: relative;
      }
      .sem::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: 5px;
        width: 95%;
        height: 1px;
        background: #c084fc;
        opacity: 0;
        transition: 0.3s;
      }
      .sem:hover::after {
        bottom: -2px;
        opacity: 1;
      }
      .sem:hover {
        color: #c084fc;
      }
      .model-card-img {
        transition: transform 450ms cubic-bezier(0.2, 0.8, 0.2, 1);
      }
      .model-card:hover .model-card-img {
        transform: scale(1.04);
      }
    </style>
  </head>

  <body class="bg-black text-white font-sans min-h-screen flex flex-col justify-between overflow-x-hidden">
    
    <nav class="relative z-50 w-full bg-black/10 backdrop-blur-xl border-b border-white/5 font-[Inter]">
      <div class="mx-auto max-w-7xl flex items-center justify-between px-6 py-5">
        <a
          href="/"
          class="animate-[shine_7s_linear_infinite] bg-[linear-gradient(90deg,#000,#1A0B2E_20%,#8A2BE2_50%,#D8B4FE_75%,#000)] bg-[length:200%_100%] bg-clip-text text-transparent text-lg font-extrabold tracking-[.35em] uppercase"
        >
          LAND CRUISER
        </a>

        <div class="hidden md:flex items-center gap-8 uppercase text-sm tracking-[.22em] text-white/70">
          <a class="sem" href="/">Home</a>
          <a class="sem" href="/about">About</a>
          <a class="sem" href="/contact/models">Models</a>
          <a class="sem" href="/gallery">Gallery</a>
          <a class="sem" href="/contact">Contact</a>

          <a
            href="/auth/login"
            class="border border-white/20 px-5 py-2 rounded-full hover:border-violet-400 hover:text-violet-300 transition"
          >
            Login
          </a>
          <a
            href="/auth/register"
            class="rounded-full bg-violet-600 px-5 py-2 text-white hover:bg-violet-500 transition"
          >
            Register
          </a>
        </div>

        <div class="md:hidden flex items-center gap-3">
          <a href="/auth/login" class="text-sm border border-white/20 px-3 py-1 rounded-full text-white/90">
            Login
          </a>
          <button id="menu-btn" class="text-2xl focus:outline-none z-50 relative p-1">
            ☰
          </button>
        </div>
      </div>

      <div id="mobile-menu" class="hidden fixed inset-0 z-40 bg-black/95 backdrop-blur-2xl flex flex-col items-center justify-center gap-6 uppercase text-base tracking-[.25em] text-white/80 transition-all duration-300">
        <a class="sem py-2 text-lg" href="/">Home</a>
        <a class="sem py-2 text-lg" href="/about">About</a>
        <a class="sem py-2 text-lg" href="/contact/models">Models</a>
        <a class="sem py-2 text-lg" href="/gallery">Gallery</a>
        <a class="sem py-2 text-lg" href="/contact">Contact</a>
        
        <div class="flex flex-col w-full px-12 gap-4 mt-6">
          <a href="/auth/login" class="text-center border border-white/20 py-3 rounded-full hover:border-violet-400 hover:text-violet-300 transition">
            Login
          </a>
          <a href="/auth/register" class="text-center rounded-full bg-violet-600 py-3 text-white hover:bg-violet-500 transition">
            Register
          </a>
        </div>
      </div>
    </nav>

    <main class="flex-grow w-full relative z-10">
      
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -z-10 w-[500px] h-[500px] bg-violet-900/10 rounded-full blur-[130px] pointer-events-none"></div>

      <section class="w-full">
        <div class="mx-auto max-w-7xl px-6 py-14 text-center">
          <div class="inline-block rounded-full border border-white/10 bg-white/5 backdrop-blur-xl shadow-[0_0_30px_rgba(138,43,226,.18)] px-5 py-2 text-[11px] uppercase tracking-[.35em] animate-[shine_9s_linear_infinite] bg-[linear-gradient(90deg,#000,#1A0B2E,#8A2BE2,#D8B4FE,#000)] bg-[length:200%_100%] bg-clip-text text-transparent">
            Luxury · Performance · Legacy
          </div>
          <h1 class="mt-6 text-3xl font-light sm:text-4xl md:text-5xl leading-tight bg-[linear-gradient(90deg,#fff,#d8b4fe,#8A2BE2)] bg-clip-text text-transparent">
            Explore the <span class="font-semibold">Land Cruiser Range</span>
          </h1>
          <p class="mt-4 max-w-2xl mx-auto text-sm sm:text-base text-gray-300 italic">
            From refined urban editions to purpose-built off-road variants — view specs, features, and premium configurations.
          </p>
        </div>
      </section>

      <section id="models" class="mx-auto max-w-7xl px-6 py-8">
        <% if (models && models.length > 0) { %>
          <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            <% models.forEach(model => { %>
              <article class="model-card group rounded-2xl overflow-hidden border border-white/10 bg-white/5 backdrop-blur-md shadow-lg transition-all duration-300 hover:border-[#8A2BE2]/40 hover:shadow-[0_0_20px_rgba(138,43,226,0.15)]">
                
                <div class="h-56 w-full overflow-hidden bg-black relative">
                  <img src="<%= model.image %>" alt="Land Cruiser <%= model.modelName %>" class="model-card-img h-full w-full object-cover object-center" />
                </div>

                <div class="p-6">
                  <h3 class="text-xl font-semibold tracking-wide text-white/90"><%= model.modelName %></h3>
                  <p class="mt-2 text-sm text-gray-400 leading-relaxed min-h-[40px]"><%= model.tagline || model.description.substring(0, 100) %></p>

                  <ul class="mt-5 grid gap-2.5 text-sm border-t border-white/5 pt-4 text-gray-300">
                    <% if (model.engine) { %>
                      <li class="flex justify-between"><span class="text-white/40 uppercase text-xs tracking-wider">Engine</span><span class="font-medium text-white/90"><%= model.engine %></span></li>
                    <% } %>
                    <% if (model.horsepower) { %>
                      <li class="flex justify-between"><span class="text-white/40 uppercase text-xs tracking-wider">Power</span><span class="font-medium text-white/90"><%= model.horsepower %> hp</span></li>
                    <% } %>
                    <% if (model.transmission) { %>
                      <li class="flex justify-between"><span class="text-white/40 uppercase text-xs tracking-wider">Gearbox</span><span class="font-medium text-white/90 text-right"><%= model.transmission %></span></li>
                    <% } %>
                    <% if (model.seatingCapacity) { %>
                      <li class="flex justify-between"><span class="text-white/40 uppercase text-xs tracking-wider">Seating</span><span class="font-medium text-white/90"><%= model.seatingCapacity %> Seats</span></li>
                    <% } %>
                  </ul>

                  <div class="mt-6 flex items-center justify-between border-t border-white/5 pt-4">
                    <span class="text-lg font-bold text-white tracking-wide"><%= model.price %> <span class="text-xs font-normal text-gray-400"><%= model.currency %></span></span>
                    <% if (model.featured) { %>
                      <span class="text-[10px] uppercase tracking-widest bg-violet-500/10 border border-violet-500/30 text-violet-300 px-3 py-1 rounded-full">Featured</span>
                    <% } %>
                  </div>

                  <div class="mt-6 flex gap-3">
                    <a href="#" class="flex-1 rounded-full text-center border border-[#8A2BE2]/40 text-xs uppercase tracking-wider font-semibold bg-[#8A2BE2]/20 py-3 backdrop-blur-xl hover:bg-[#8A2BE2]/40 transition">Details</a>
                    <a href="#" class="flex-1 rounded-full text-center border border-white/10 text-xs uppercase tracking-wider text-gray-300 py-3 backdrop-blur-xl hover:border-white/30 transition">Compare</a>
                  </div>
                </div>
              </article>
            <% }); %>
          </div>
        <% } else { %>
          <div class="text-center py-16 border border-white/5 bg-white/5 backdrop-blur-md rounded-2xl">
            <p class="text-gray-400 italic">No models available at the moment. Please check back soon!</p>
          </div>
        <% } %>
      </section>

      <section class="mx-auto max-w-7xl px-6 py-14 text-center">
        <p class="text-sm sm:text-base text-gray-300 italic">Want a custom spec or color? Contact your dealer to configure your tailored Land Cruiser.</p>
        <div class="mt-6">
          <a
            href="#"
            class="rounded-full inline-block border border-[#8A2BE2]/40 text-sm bg-[#8A2BE2]/10 px-8 py-3 backdrop-blur-xl hover:shadow-[0_0_12px_rgba(138,43,226,.6)] transition"
          >
            Find Dealer
          </a>
        </div>
      </section>
    </main>

    <footer class="border-t border-white/5 bg-black/95 w-full">
      <div class="mx-auto max-w-7xl px-6 py-8 text-center text-xs tracking-widest text-white/40 uppercase">
        © 2026 Signature Edition Land Cruiser — All rights reserved.
      </div>
    </footer>

    <script>
      const menuBtn = document.getElementById('menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      menuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
        if (mobileMenu.classList.contains('hidden')) {
          menuBtn.innerHTML = '☰';
        } else {
          menuBtn.innerHTML = '✕';
        }
      });
    </script>
  </body>
</html>