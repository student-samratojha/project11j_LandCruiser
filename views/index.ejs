<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0" />
    <title>Land Cruiser</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      @keyframes shine {
        from {
          background-position: 200% center;
        }
        to {
          background-position: -200% center;
        }
      }
      .sem {
        position: relative;
      }
      .sem::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: 5px;
        width: 95%;
        height: 1px;
        background: #c084fc;
        opacity: 0;
        transition: 0.3s;
      }
      .sem:hover::after {
        bottom: -2px;
        opacity: 1;
      }
      .sem:hover {
        color: #c084fc;
      }
    </style>
  </head>
  <body class="bg-black text-white overflow-x-hidden font-sans">
    <section
      class="relative min-h-screen overflow-hidden flex flex-col justify-between"
    >
      <img
        src="/heros.png"
        class="absolute inset-0 w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-black/20"></div>
      <div
        class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/20 to-black"
      ></div>
      <div
        class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle,transparent_35%,rgba(0,0,0,.18)_70%,rgba(0,0,0,.65)_100%)]"
      ></div>

      <nav
        class="absolute top-0 left-0 z-50 w-full bg-black/10 backdrop-blur-xl border-b border-white/5 font-[Inter]"
      >
        <div
          class="mx-auto max-w-7xl flex items-center justify-between px-6 py-5"
        >
          <a
            href="/"
            class="animate-[shine_7s_linear_infinite] bg-[linear-gradient(90deg,#000,#1A0B2E_20%,#8A2BE2_50%,#D8B4FE_75%,#000)] bg-[length:200%_100%] bg-clip-text text-transparent text-lg font-extrabold tracking-[.35em] uppercase"
          >
            LAND CRUISER
          </a>

          <div
            class="hidden md:flex items-center gap-8 uppercase text-sm tracking-[.22em] text-white/70"
          >
            <a class="sem" href="/">Home</a>
            <a class="sem" href="/about">About</a>
            <a class="sem" href="/contact/models">Models</a>
            <a class="sem" href="/gallery">Gallery</a>
            <a class="sem" href="/contact">Contact</a>

            <a
              href="/auth/login"
              class="border border-white/20 px-5 py-2 rounded-full hover:border-violet-400 hover:text-violet-300 transition"
            >
              Login
            </a>

            <a
              href="/auth/register"
              class="rounded-full bg-violet-600 px-5 py-2 text-white hover:bg-violet-500 transition"
            >
              Register
            </a>
          </div>

          <div class="md:hidden flex items-center gap-3">
            <a
              href="/auth/login"
              class="text-sm border border-white/20 px-3 py-1 rounded-full text-white/90"
            >
              Login
            </a>

            <button
              id="menu-btn"
              class="text-2xl focus:outline-none z-50 relative p-1 text-white"
            >
              ☰
            </button>
          </div>
        </div>

        <div
          id="mobile-menu"
          class="hidden fixed inset-0 z-40 bg-black/95 backdrop-blur-2xl flex flex-col items-center justify-center gap-6 uppercase text-base tracking-[.25em] text-white/80 transition-all duration-300"
        >
          <a class="sem py-2 text-lg" href="/">Home</a>
          <a class="sem py-2 text-lg" href="/about">About</a>
          <a class="sem py-2 text-lg" href="/contact/models">Models</a>
          <a class="sem py-2 text-lg" href="/gallery">Gallery</a>
          <a class="sem py-2 text-lg" href="/contact">Contact</a>

          <div class="flex flex-col w-full px-12 gap-4 mt-6">
            <a
              href="/auth/login"
              class="text-center border border-white/20 py-3 rounded-full hover:border-violet-400 hover:text-violet-300 transition"
            >
              Login
            </a>
            <a
              href="/auth/register"
              class="text-center rounded-full bg-violet-600 py-3 text-white hover:bg-violet-500 transition"
            >
              Register
            </a>
          </div>
        </div>
      </nav>

      <div class="relative z-40 px-6 mt-auto pb-4 md:pb-6 w-full">
        <div class="mx-auto max-w-6xl">
          <h1
            class="text-3xl sm:text-4xl md:text-5xl font-light leading-tight bg-[linear-gradient(90deg,#fff,#d8b4fe,#8A2BE2)] bg-clip-text text-transparent"
          >
            Command Every Journey.
            <span class="block font-semibold">Own Every Horizon.</span>
          </h1>

          <p class="mt-4 max-w-3xl text-sm sm:text-base text-gray-300 italic">
            Discover the
            <span class="text-[#C084FC] font-semibold"
              >premium black Land Cruiser</span
            >
            experience with refined interiors, unmatched capability, and
            <span class="text-white">signature presence</span> designed for the
            most demanding roads.
          </p>

          <div class="mt-6 flex flex-wrap items-center gap-4">
            <div
              class="rounded-full border border-white/10 bg-white/5 backdrop-blur-xl shadow-[0_0_30px_rgba(138,43,226,.18)] px-4 py-2.5 sm:px-5 sm:py-3 text-[10px] sm:text-[11px] uppercase tracking-[.35em] animate-[shine_9s_linear_infinite] bg-[linear-gradient(90deg,#000,#1A0B2E,#8A2BE2,#D8B4FE,#000)] bg-[length:200%_100%] bg-clip-text text-transparent"
            >
              Luxury · Performance · Legacy
            </div>

            <a
              href="/contact/models"
              class="rounded-full text-center border border-[#8A2BE2]/40 text-xs sm:text-sm bg-[#8A2BE2]/10 px-6 py-2.5 sm:px-8 sm:py-2 backdrop-blur-xl hover:shadow-[0_0_12px_rgba(138,43,226,.6)] transition w-full sm:w-auto"
            >
              Explore Collection
            </a>
          </div>
        </div>
      </div>
    </section>

    <script>
      const menuBtn = document.getElementById("menu-btn");
      const mobileMenu = document.getElementById("mobile-menu");

      menuBtn.addEventListener("click", () => {
        mobileMenu.classList.toggle("hidden");
        // Hamburger icon ko close (✕) icon me badalne ke liye
        if (mobileMenu.classList.contains("hidden")) {
          menuBtn.innerHTML = "☰";
        } else {
          menuBtn.innerHTML = "✕";
        }
      });
    </script>
  </body>
</html>
