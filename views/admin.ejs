<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">

  <title>Land Cruiser | Admin Dashboard</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    @keyframes shine{
      from{background-position:200% center;}
      to{background-position:-200% center;}
    }

    .sem{
      position:relative;
    }

    .sem::after{
      content:"";
      position:absolute;
      left:0;
      bottom:5px;
      width:100%;
      height:1px;
      background:#c084fc;
      opacity:0;
      transition:.35s;
    }

    .sem:hover::after{
      bottom:-4px;
      opacity:1;
    }

    .sem:hover{
      color:#c084fc;
    }
  </style>
</head>

<body class="bg-black text-white overflow-x-hidden">

<div class="relative min-h-screen">

    <!-- Background -->

    <img
    src="/heros.png"
    class="absolute inset-0 w-full h-full object-cover object-center">

    <div class="absolute inset-0 bg-black/70"></div>

    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/40 to-black"></div>

    <div class="absolute inset-0 bg-[radial-gradient(circle,transparent_35%,rgba(0,0,0,.25)_70%,rgba(0,0,0,.85)_100%)]"></div>


<!-- ================= NAVBAR ================= -->

<nav class="relative z-50 border-b border-white/10 backdrop-blur-xl bg-black/20">

<div class="max-w-7xl mx-auto flex justify-between items-center px-6 py-5">

<a
href="/"
class="animate-[shine_7s_linear_infinite] bg-[linear-gradient(90deg,#000,#1A0B2E,#8A2BE2,#D8B4FE,#000)] bg-[length:200%_100%] bg-clip-text text-transparent uppercase tracking-[.35em] font-extrabold">

LAND CRUISER

</a>


<div class="flex items-center gap-8 text-sm uppercase tracking-[.2em]">

<a
href="/secure/add"
class="rounded-full bg-violet-600 px-5 py-2 hover:bg-violet-500 duration-300">

+ Add New Model

</a>
<a
href="/auth/logout"
class="rounded-full border border-violet-500 px-5 py-2 hover:bg-violet-600 duration-300">

Logout

</a>

</div>

</div>

</nav>

<!-- ================= MAIN ================= -->

<div class="relative z-40 max-w-7xl mx-auto px-6 py-12">

<h1
class="text-5xl font-light bg-[linear-gradient(90deg,#fff,#d8b4fe,#8A2BE2)] bg-clip-text text-transparent">

Admin Dashboard

</h1>

<p class="mt-2 text-gray-300">

Manage Models, Users & Contacts

</p>


<!-- ================= STATS ================= -->

<div class="grid md:grid-cols-3 gap-7 mt-10">

<div class="rounded-3xl border border-violet-500/20 bg-white/5 backdrop-blur-xl p-8">

<p class="uppercase tracking-[.3em] text-xs text-gray-400">

MODELS

</p>

<h2 class="text-5xl mt-5 font-bold text-violet-300">

<%= models.length %>

</h2>

</div>

<div class="rounded-3xl border border-violet-500/20 bg-white/5 backdrop-blur-xl p-8">

<p class="uppercase tracking-[.3em] text-xs text-gray-400">

CONTACTS

</p>

<h2 class="text-5xl mt-5 font-bold text-violet-300">

<%= contacts.length %>

</h2>

</div>

<div class="rounded-3xl border border-violet-500/20 bg-white/5 backdrop-blur-xl p-8">

<p class="uppercase tracking-[.3em] text-xs text-gray-400">

ADMINS

</p>

<h2 class="text-5xl mt-5 font-bold text-violet-300">

<%= users.length %>

</h2>

</div>

</div>



<!-- ================= MODELS ================= -->

<div class="mt-14">

<h2 class="text-3xl mb-8 font-light">

Vehicle Models

</h2>

<% models.forEach(model=>{ %>

<div class="mb-5 rounded-3xl border border-white/10 bg-white/5 backdrop-blur-xl p-6 flex justify-between items-center">

<div>

<h2 class="text-2xl font-semibold">

<%= model.modelName %>

</h2>

<p class="text-gray-400 mt-2">

<%= model.year %>

</p>

</div>

<div class="flex gap-4">

<a
href="/secure/model/<%=model._id%>/edit"
class="rounded-full border border-green-500 px-5 py-2 hover:bg-green-600">

Edit

</a>

<form
action="/secure/model/<%=model._id%>/delete"
method="POST">

<button
class="rounded-full border border-red-500 px-5 py-2 hover:bg-red-600">

Delete

</button>

</form>

<form
action="/secure/model/<%=model._id%>/restore"
method="POST">

<button
class="rounded-full border border-violet-500 px-5 py-2 hover:bg-violet-600">

Restore

</button>

</form>

</div>

</div>

<% }) %>
<!-- ================= CONTACTS ================= -->

<div class="mt-16">

  <h2 class="mb-8 text-3xl font-light">
    Contact Messages
  </h2>

  <% contacts.forEach(contact=>{ %>

  <div
    class="mb-5 flex items-center justify-between rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur-xl">

    <div>

      <h3 class="text-xl font-semibold text-violet-300">
        <%= contact.name %>
      </h3>

      <p class="mt-1 text-gray-300">
        <%= contact.email %>
      </p>

      <% if(contact.message){ %>

      <p class="mt-3 text-sm text-gray-400">
        <%= contact.message %>
      </p>

      <% } %>

    </div>

    <div class="flex gap-4">

      <form
        action="/secure/contact/<%= contact._id %>/delete"
        method="POST">

        <button
          class="rounded-full border border-red-500 px-5 py-2 transition hover:bg-red-600">

          Delete

        </button>

      </form>

      <form
        action="/secure/contact/<%= contact._id %>/restore"
        method="POST">

        <button
          class="rounded-full border border-violet-500 px-5 py-2 transition hover:bg-violet-600">

          Restore

        </button>

      </form>

    </div>

  </div>

  <% }) %>

</div>

<!-- ================= ADMINS ================= -->

<div class="mt-16">

  <h2 class="mb-8 text-3xl font-light">

    User Accounts

  </h2>

  <% users.forEach(admin=>{ %>

  <div
    class="mb-5 flex items-center justify-between rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur-xl">

    <div class="flex items-center gap-5">

      <img
        src="<%= admin.profilePic || '/default-user.png' %>"
        class="h-16 w-16 rounded-full border-2 border-violet-500 object-cover">

      <div>

        <h3 class="text-xl font-semibold text-violet-300">

          <%= admin.name %>

        </h3>

        <p class="text-gray-300">

          <%= admin.email %>

        </p>

      </div>

    </div>

<div class="flex gap-4">

  <% if(admin.role !== "admin"){ %>

      <% if(admin.isDeleted){ %>

      <form action="/secure/user/restore" method="POST">
        <input
          type="hidden"
          name="id"
          value="<%= admin._id %>"
        />

        <button
          class="rounded-full border border-violet-500 px-5 py-2 transition hover:bg-violet-600">

          Restore

        </button>
      </form>

      <% } else { %>

      <form action="/secure/user/delete" method="POST">
        <input
          type="hidden"
          name="id"
          value="<%= admin._id %>"
        />

        <button
          class="rounded-full border border-red-500 px-5 py-2 transition hover:bg-red-600">

          Delete

        </button>
      </form>

      <% } %>

  <% } %>

</div>

  </div>

  <% }) %>

</div>

<!-- ================= FOOTER ================= -->

<footer
  class="mt-20 border-t border-white/10 py-8 text-center text-sm text-gray-500">

  © 2026 LAND CRUISER • Premium Admin Dashboard

</footer>

</div>

</div>

</body>

</html>