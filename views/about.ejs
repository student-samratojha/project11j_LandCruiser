<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>About — Land Cruiser</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-black text-white">
    <header class="border-b border-white/10 bg-black/80">
      <div class="mx-auto max-w-7xl px-6 py-5">
        <div class="flex items-center justify-between">
          <a href="/" class="text-lg font-semibold uppercase tracking-[0.35em] text-amber-300" style="font-family: 'Cormorant Garamond', serif">LAND CRUISER</a>
          <nav class="hidden md:flex items-center gap-8 uppercase text-sm tracking-[0.22em] text-white/70">
            <a href="/" class="transition hover:text-white">Home</a>
           
            <a href="/gallery" class="transition hover:text-white">Gallery</a>
          </nav>
        </div>
      </div>
    </header>

    <main>
      <!-- Hero / Intro -->
      <section class="relative w-full bg-black">
        <div class="mx-auto max-w-7xl px-6 py-12 lg:py-20">
          <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:items-center">
            <div class="order-2 lg:order-1">
              <div class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[11px] uppercase tracking-[0.35em] text-amber-200/85 inline-block">Signature Edition</div>

              <h1 class="mt-6 text-3xl font-light leading-tight sm:text-4xl md:text-5xl lg:text-6xl" style="font-family: 'Cormorant Garamond', serif">The Premium Black Land Cruiser</h1>

              <p class="mt-6 text-base text-white/75 max-w-2xl">A synthesis of enduring capability and refined luxury — engineered for explorers who demand comfort, control, and presence. The Land Cruiser balances an iconic silhouette with modern technology and unparalleled off-road performance.</p>

              <div class="mt-8 flex flex-wrap gap-4">
                <a href="/" class="inline-flex items-center justify-center rounded-full bg-amber-400 px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg transition hover:bg-amber-300">Explore Model</a>
                <a href="/gallery" class="inline-flex items-center justify-center rounded-full border border-white/15 bg-white/5 px-6 py-3 text-sm text-white/90 transition hover:border-amber-200">View Gallery</a>
              </div>
            </div>

            <div class="order-1 lg:order-2">
              <div class="rounded-2xl overflow-hidden border border-white/10 bg-gradient-to-b from-white/5 to-transparent">
                <img src="/about.png" alt="Land Cruiser" class="w-full object-cover" />
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Overview -->
      <section id="overview" class="border-t border-white/5 bg-black/95">
        <div class="mx-auto max-w-6xl px-6 py-14">
          <h2 class="text-2xl font-semibold">Overview</h2>
          <p class="mt-4 text-white/75 max-w-4xl">The Land Cruiser is built to deliver confidence in every environment. From long highway journeys to the most demanding off-road trails, it combines robust engineering, a luxurious interior, and advanced driver assistance systems to keep you comfortable and in control.</p>
        </div>
      </section>

      <!-- Specs -->
      <section id="specs" class="bg-slate-900/50">
        <div class="mx-auto max-w-6xl px-6 py-14">
          <h2 class="text-2xl font-semibold">Key Specifications</h2>

          <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
            <div class="rounded-xl border border-white/10 bg-slate-900/60 p-6">
              <p class="text-sm uppercase tracking-[0.2em] text-amber-200/80">Powertrain</p>
              <p class="mt-3 text-lg font-semibold">3.5L V6 Turbo</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-slate-900/60 p-6">
              <p class="text-sm uppercase tracking-[0.2em] text-amber-200/80">Horsepower</p>
              <p class="mt-3 text-lg font-semibold">409 hp</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-slate-900/60 p-6">
              <p class="text-sm uppercase tracking-[0.2em] text-amber-200/80">Transmission</p>
              <p class="mt-3 text-lg font-semibold">10-speed automatic</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-slate-900/60 p-6">
              <p class="text-sm uppercase tracking-[0.2em] text-amber-200/80">Towing</p>
              <p class="mt-3 text-lg font-semibold">Up to 9,000 lbs</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Features -->
      <section id="features" class="border-t border-white/5">
        <div class="mx-auto max-w-6xl px-6 py-14">
          <h2 class="text-2xl font-semibold">Notable Features</h2>

          <div class="mt-6 grid gap-8 md:grid-cols-2">
            <div>
              <h3 class="text-lg font-semibold">Refined Interior</h3>
              <p class="mt-3 text-white/75">Hand-stitched leather, ambient lighting, and an intuitive infotainment system create a cabin worthy of extended journeys.</p>
            </div>

            <div>
              <h3 class="text-lg font-semibold">Advanced Safety</h3>
              <p class="mt-3 text-white/75">A comprehensive suite of driver-assist features helps protect occupants and increases off-road confidence.</p>
            </div>

            <div>
              <h3 class="text-lg font-semibold">Off-Road Capability</h3>
              <p class="mt-3 text-white/75">Multi-terrain select, locking differentials, and durable chassis engineering enable unmatched capability across varied terrain.</p>
            </div>

            <div>
              <h3 class="text-lg font-semibold">Connectivity</h3>
              <p class="mt-3 text-white/75">Seamless smartphone integration, premium audio, and multiple USB-C ports keep everyone connected and entertained.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Gallery CTA -->
      <section id="gallery" class="bg-black/95">
        <div class="mx-auto max-w-6xl px-6 py-14 text-center">
          <h2 class="text-2xl font-semibold">Gallery</h2>
          <p class="mt-4 text-white/75 max-w-2xl mx-auto">A curated collection of the Land Cruiser in action — from urban streets to remote landscapes.</p>

          <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            <img src="./hero.jpg" alt="gallery1" class="rounded-xl border border-white/10 object-cover" />
            <img src="./heros.png" alt="gallery2" class="rounded-xl border border-white/10 object-cover" />
            <img src="./about.png" alt="gallery3" class="rounded-xl border border-white/10 object-cover" />
          </div>
        </div>
      </section>
    </main>

    <footer class="border-t border-white/5 bg-black/95">
      <div class="mx-auto max-w-7xl px-6 py-8 text-center text-sm text-white/60">
        © 2025 Signature Edition Land Cruiser — All rights reserved.
      </div>
    </footer>
  </body>
</html>